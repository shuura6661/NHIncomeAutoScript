# NHIncomeAutoScript — environment variable template
# Copy this file to ".env" and fill in your real values:
#   cp .env.example .env
# The real .env is git-ignored and must NEVER be committed.

# --- Accounts (numbered, starting at 1) -------------------------------------
# Add as many accounts as you like by incrementing the suffix: 1, 2, 3, ...
# The script keeps reading EMAILn/PASSWORDn/SERVER_NAMEn until one is missing.

EMAIL1="your_email@gmail.com"
PASSWORD1="your_password"
# Use the EXACT server name as shown in-game, including the level bracket:
SERVER_NAME1="Server 35 - SolomonKent [Lv. 3]"

# Second account (optional) — delete if unused:
# EMAIL2="second_email@gmail.com"
# PASSWORD2="second_password"
# SERVER_NAME2="Server 35 - DeanMalcolm [Lv. 3]"

# --- Telegram notifications (used by telebot.py) ----------------------------
# Bot token from @BotFather and your chat ID. Leave blank to skip notifications.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
